<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Jeopardy! — Buzzer</title>
<link href="https://fonts.googleapis.com/css2?family=Anton&family=Barlow+Condensed:wght@400;600;700&family=Barlow:wght@400;500&display=swap" rel="stylesheet">
<script>
(function(){
  var SRCS=['https://js.pusher.com/8.2.0/pusher.min.js','https://cdn.jsdelivr.net/npm/pusher-js@8.2.0/dist/web/pusher.min.js','https://cdnjs.cloudflare.com/ajax/libs/pusher/8.2.0/pusher.min.js'];
  function load(idx){
    if(idx>=SRCS.length){console.error('Pusher failed to load from all CDNs');return;}
    var s=document.createElement('script');s.src=SRCS[idx];
    s.onerror=function(){load(idx+1);};
    document.head.appendChild(s);
  }
  load(0);
})();
</script>
<style>
:root{
  --jblue:#060CE9;--jgold:#FFD700;--jred:#e63946;--jgreen:#2dc653;--jwhite:#f0f2ff;
  --pb:rgba(255,255,255,.13);--r:8px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;overflow:hidden}
body{font-family:'Barlow',sans-serif;background:#02031a;color:var(--jwhite);height:100vh;overflow:hidden}

.screen{display:none;min-height:100vh}
.screen.active{display:flex;flex-direction:column}

/* ══ JOIN SCREEN ══ */
#join-screen{
  background:radial-gradient(ellipse at 50% 10%,#1020b8 0%,#02031a 60%);
  align-items:center;justify-content:center;padding:2rem 1rem
}
.join-card{
  background:rgba(255,255,255,.05);border:1px solid var(--pb);
  border-radius:16px;padding:2.2rem 1.8rem;max-width:360px;width:100%;text-align:center
}
.jlogo{font-family:'Anton',sans-serif;font-size:2.4rem;color:var(--jgold);letter-spacing:.06em;text-shadow:3px 3px 0 #7a6000;margin-bottom:.25rem}
.jsub{font-family:'Barlow Condensed',sans-serif;font-size:.78rem;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,.3);margin-bottom:1.8rem}
.join-card input{
  width:100%;background:rgba(255,255,255,.08);border:1px solid var(--pb);
  border-radius:var(--r);color:#fff;font-family:'Barlow Condensed',sans-serif;
  font-size:1.2rem;letter-spacing:.08em;padding:.7rem 1rem;text-align:center;
  margin-bottom:.8rem;transition:border-color .2s
}
.join-card input:focus{outline:none;border-color:var(--jgold)}
.btn-main{font-family:'Anton',sans-serif;font-size:1.1rem;letter-spacing:.08em;padding:.7rem 1.8rem;border-radius:var(--r);border:none;cursor:pointer;transition:all .15s;width:100%}
.btn-main.primary{background:var(--jgold);color:#1a0000;box-shadow:0 4px 18px rgba(255,215,0,.25)}
.btn-main.primary:hover{background:#ffe84d;transform:translateY(-1px)}
.jerr{color:var(--jred);font-family:'Barlow Condensed',sans-serif;font-size:.82rem;letter-spacing:.06em;margin-top:.5rem;min-height:1.1rem}

/* ══ PLAYER SCREEN ══ */
#player-screen{
  background:#02031a;align-items:center;justify-content:space-between;
  padding:env(safe-area-inset-top,.5rem) 1rem env(safe-area-inset-bottom,1.5rem);
  min-height:100vh;position:relative;overflow:hidden
}
#player-screen::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse at 50% 50%,rgba(6,12,233,.22) 0%,transparent 70%);
  pointer-events:none
}

.ptop{width:100%;max-width:400px;text-align:center;z-index:1;padding-top:.5rem}
.gtitle{font-family:'Anton',sans-serif;font-size:1.5rem;color:var(--jgold);letter-spacing:.1em;margin-bottom:.2rem}
.rcode{font-family:'Barlow Condensed',sans-serif;font-size:.72rem;letter-spacing:.22em;text-transform:uppercase;color:rgba(255,255,255,.28)}

.buzzer-wrap{flex:1;display:flex;align-items:center;justify-content:center;z-index:1;padding:1.5rem 0}

#buzz-btn{
  width:min(72vw,280px);height:min(72vw,280px);
  border-radius:50%;border:none;cursor:pointer;
  position:relative;transition:transform .08s,box-shadow .08s;
  background:radial-gradient(circle at 35% 35%,#1c30ff,var(--jblue) 50%,#03047a);
  box-shadow:0 0 0 6px rgba(6,12,233,.3),0 0 0 12px rgba(6,12,233,.14),0 20px 55px rgba(6,12,233,.55),inset 0 2px 8px rgba(255,255,255,.18);
  display:flex;align-items:center;justify-content:center;flex-direction:column;gap:.35rem;
  -webkit-tap-highlight-color:transparent;user-select:none;touch-action:manipulation
}
#buzz-btn:active:not(:disabled){
  transform:scale(.92);
  box-shadow:0 0 0 4px rgba(6,12,233,.2),0 8px 28px rgba(6,12,233,.45),inset 0 3px 12px rgba(0,0,0,.28)
}
#buzz-btn:disabled{cursor:not-allowed}

#buzz-btn.st-ready{background:radial-gradient(circle at 35% 35%,#1c30ff,var(--jblue) 50%,#03047a)}
#buzz-btn.st-locked{background:radial-gradient(circle at 35% 35%,#c72530,var(--jred) 50%,#7a1019);box-shadow:0 0 0 6px rgba(230,57,70,.28),0 20px 45px rgba(230,57,70,.38),inset 0 2px 8px rgba(255,255,255,.12);opacity:.7}
#buzz-btn.st-buzzed{background:radial-gradient(circle at 35% 35%,#38d96a,var(--jgreen) 50%,#158533);box-shadow:0 0 0 6px rgba(45,198,83,.32),0 0 0 14px rgba(45,198,83,.14),0 20px 55px rgba(45,198,83,.48),inset 0 2px 8px rgba(255,255,255,.22);animation:bpulse .5s ease}
#buzz-btn.st-correct{background:radial-gradient(circle at 35% 35%,#38d96a,var(--jgreen) 50%,#158533);box-shadow:0 0 0 8px rgba(45,198,83,.4),0 20px 55px rgba(45,198,83,.5)}
#buzz-btn.st-wrong{background:radial-gradient(circle at 35% 35%,#c72530,var(--jred) 50%,#7a1019);box-shadow:0 0 0 8px rgba(230,57,70,.4),0 20px 50px rgba(230,57,70,.48)}
@keyframes bpulse{0%{transform:scale(1)}30%{transform:scale(1.08)}60%{transform:scale(.97)}100%{transform:scale(1)}}

.blabel{font-family:'Anton',sans-serif;font-size:clamp(1.5rem,8vw,2.1rem);letter-spacing:.08em;color:#fff;text-shadow:0 2px 8px rgba(0,0,0,.35);pointer-events:none}
.bsub{font-family:'Barlow Condensed',sans-serif;font-size:.78rem;letter-spacing:.15em;text-transform:uppercase;color:rgba(255,255,255,.5);pointer-events:none}

.pbot{width:100%;max-width:400px;z-index:1}
.pstatus{text-align:center;font-family:'Barlow Condensed',sans-serif;font-size:.88rem;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.28);margin-bottom:.9rem;min-height:1.2rem;transition:color .2s}
.pstatus.open{color:var(--jgreen)}
.pstatus.locked{color:var(--jred)}
.pstatus.buzzed{color:var(--jgold)}
.pstatus.correct{color:var(--jgreen)}
.pstatus.wrong{color:var(--jred)}

.score-display{display:flex;align-items:center;justify-content:space-between;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:var(--r);padding:.65rem 1rem}
.sd-name{font-family:'Barlow Condensed',sans-serif;font-size:.95rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:rgba(255,255,255,.65)}
.sd-score{font-family:'Anton',sans-serif;font-size:1.55rem;color:var(--jgold)}
.sd-score.neg{color:var(--jred)}

/* connecting overlay */
.conn{display:none;position:fixed;inset:0;background:rgba(2,3,26,.9);z-index:500;align-items:center;justify-content:center;flex-direction:column;gap:1rem;font-family:'Barlow Condensed',sans-serif;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.4);font-size:.85rem;backdrop-filter:blur(4px)}
.conn.show{display:flex}
.spinner{width:36px;height:36px;border:3px solid rgba(255,215,0,.16);border-top-color:var(--jgold);border-radius:50%;animation:spin .7s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}

/* ripple */
.ripple{position:absolute;border-radius:50%;background:rgba(255,255,255,.28);transform:scale(0);animation:rip .55s linear;pointer-events:none}
@keyframes rip{to{transform:scale(4);opacity:0}}
</style>
</head>
<body>

<!-- JOIN -->
<div id="join-screen" class="screen active">
  <div class="join-card">
    <div class="jlogo">JEOPARDY!</div>
    <div class="jsub">Buzzer System</div>
    <input type="text" id="j-name" placeholder="Your name" maxlength="20" autocomplete="off">
    <input type="text" id="j-room" placeholder="Room code" maxlength="12" style="text-transform:uppercase;letter-spacing:.18em" autocomplete="off">
    <button class="btn-main primary" onclick="doJoin()">Join Game →</button>
    <div class="jerr" id="jerr"></div>
  </div>
</div>

<!-- PLAYER BUZZER -->
<div id="player-screen" class="screen">
  <div class="ptop">
    <div class="gtitle">JEOPARDY!</div>
    <div class="rcode" id="room-label">ROOM: —</div>
  </div>

  <div class="buzzer-wrap">
    <button id="buzz-btn" class="st-locked" onclick="doBuzz(event)" disabled>
      <span class="blabel" id="blabel">BUZZ</span>
      <span class="bsub" id="bsub">Connecting…</span>
    </button>
  </div>

  <div class="pbot">
    <div class="pstatus" id="pstatus">Connecting to room…</div>
    <div class="score-display">
      <span class="sd-name" id="sd-name">—</span>
      <span class="sd-score" id="sd-score">$0</span>
    </div>
  </div>
</div>

<div class="conn" id="conn"><div class="spinner"></div><span>Connecting…</span></div>

<script>
let pusher=null, channel=null;
let myName='', myRoom='', myId='', myScore=0;
let isLocked=true, hasBuzzed=false;

// ── AUTO-FILL FROM URL ──
(function(){
  const p=new URLSearchParams(window.location.search);
  if(p.get('room')) document.getElementById('j-room').value=p.get('room').toUpperCase();
})();

document.getElementById('j-room').addEventListener('input',function(){this.value=this.value.toUpperCase();});

function doJoin(){
  const name=document.getElementById('j-name').value.trim();
  const room=document.getElementById('j-room').value.trim().toUpperCase();
  const p=new URLSearchParams(window.location.search);
  const key=p.get('key')||'';
  const cluster=p.get('cluster')||'mt1';
  document.getElementById('jerr').textContent='';
  if(!name){document.getElementById('jerr').textContent='Enter your name';return;}
  if(!room){document.getElementById('jerr').textContent='Enter room code';return;}
  if(!key){document.getElementById('jerr').textContent='Missing Pusher key — use the link the host shared with you.';return;}
  startSession(key,cluster,room,name);
}

function startSession(key,cluster,room,name){
  myName=name; myRoom=room; myId='p_'+Math.random().toString(36).slice(2,9);
  myScore=0; isLocked=true; hasBuzzed=false;
  document.getElementById('room-label').textContent='ROOM: '+room;
  document.getElementById('sd-name').textContent=name;
  updateScore();
  showScreen('player-screen');
  initPusher(key,cluster);
}

function initPusher(key,cluster){
  if(typeof Pusher==='undefined'){
    showConn(false);
    document.getElementById('jerr').textContent='Pusher library failed to load — check your internet connection and disable any ad blockers, then refresh.';
    showScreen('join-screen');
    return;
  }
  showConn(true);
  Pusher.logToConsole=false;
  try{
    pusher=new Pusher(key,{cluster});
    pusher.connection.bind('connected',()=>{showConn(false);subscribe();});
    pusher.connection.bind('failed',()=>{showConn(false);document.getElementById('jerr').textContent='Connection failed — check your Pusher key and internet.';showScreen('join-screen');});
    pusher.connection.bind('error',e=>{showConn(false);document.getElementById('jerr').textContent='Connection error — check the room link and try again.';showScreen('join-screen');console.error(e);});
  }catch(err){
    showConn(false);
    document.getElementById('jerr').textContent='Error: '+err.message;
    showScreen('join-screen');
  }
}

function subscribe(){
  channel=pusher.subscribe('jeopardy-'+myRoom.toLowerCase());
  channel.bind('pusher:subscription_succeeded',()=>{
    announce();
    setState('ready');
  });
  channel.bind('pusher:subscription_error',()=>{
    document.getElementById('jerr').textContent='Could not join room — check room code.';
    showScreen('join-screen');
  });
  channel.bind('client-lock',data=>{
    isLocked=data.locked; hasBuzzed=false;
    setState(data.locked?'locked':'ready');
  });
  channel.bind('client-reset',()=>{
    hasBuzzed=false; setState(isLocked?'locked':'ready');
  });
  channel.bind('client-score-update',data=>{
    if(data.id===myId){
      myScore=data.score; updateScore();
      if(data.correct===true){ setState('correct'); setTimeout(()=>setState(isLocked?'locked':'ready'),2000); }
      else if(data.correct===false){ setState('wrong'); setTimeout(()=>setState(isLocked?'locked':'ready'),1600); }
    }
  });
}

function announce(){
  try{ channel.trigger('client-player-join',{id:myId,name:myName}); }catch(e){}
}

function doBuzz(e){
  if(isLocked||hasBuzzed) return;
  hasBuzzed=true;
  const btn=document.getElementById('buzz-btn');
  const rip=document.createElement('span'); rip.className='ripple';
  rip.style.cssText=`width:${btn.offsetWidth}px;height:${btn.offsetHeight}px;left:0;top:0`;
  btn.appendChild(rip); setTimeout(()=>rip.remove(),550);
  setState('buzzed');
  try{ channel.trigger('client-buzz',{id:myId,name:myName,ts:Date.now()}); }catch(ex){ console.warn('buzz failed',ex); }
  playSound();
}

function setState(st){
  const btn=document.getElementById('buzz-btn');
  const lbl=document.getElementById('blabel');
  const sub=document.getElementById('bsub');
  const status=document.getElementById('pstatus');
  btn.className=''; btn.disabled=false;
  switch(st){
    case 'ready':
      btn.classList.add('st-ready');
      lbl.textContent='BUZZ'; sub.textContent='Tap to buzz in!';
      status.textContent='🔓 Buzzers open'; status.className='pstatus open';
      hasBuzzed=false; break;
    case 'locked':
      btn.classList.add('st-locked'); btn.disabled=true;
      lbl.textContent='LOCKED'; sub.textContent='Wait for host…';
      status.textContent='🔒 Buzzers locked'; status.className='pstatus locked'; break;
    case 'buzzed':
      btn.classList.add('st-buzzed'); btn.disabled=true;
      lbl.textContent='BUZZED!'; sub.textContent='Answer the question!';
      status.textContent='🔔 You buzzed in!'; status.className='pstatus buzzed'; break;
    case 'correct':
      btn.classList.add('st-correct'); btn.disabled=true;
      lbl.textContent='✓ CORRECT'; sub.textContent='Points awarded!';
      status.textContent='✓ Correct!'; status.className='pstatus correct'; break;
    case 'wrong':
      btn.classList.add('st-wrong'); btn.disabled=true;
      lbl.textContent='✕ WRONG'; sub.textContent='Better luck next time';
      status.textContent='✕ Incorrect'; status.className='pstatus wrong'; break;
  }
}

function updateScore(){
  const s=document.getElementById('sd-score');
  const neg=myScore<0;
  s.textContent=(neg?'-':'')+'$'+Math.abs(myScore).toLocaleString();
  s.className='sd-score'+(neg?' neg':'');
}

function playSound(){
  try{
    const ctx=new(window.AudioContext||window.webkitAudioContext)();
    [0,.1].forEach((d,i)=>{
      const o=ctx.createOscillator(),g=ctx.createGain();
      o.connect(g);g.connect(ctx.destination);
      o.type='sine';o.frequency.value=i===0?660:880;
      g.gain.setValueAtTime(.4,ctx.currentTime+d);
      g.gain.exponentialRampToValueAtTime(.001,ctx.currentTime+d+.22);
      o.start(ctx.currentTime+d);o.stop(ctx.currentTime+d+.22);
    });
  }catch(e){}
}

function showScreen(id){ document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active')); document.getElementById(id).classList.add('active'); }
function showConn(v){ document.getElementById('conn').classList.toggle('show',v); }
</script>
</body>
</html>
