<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Jeopardy! — Host</title>
<link href="https://fonts.googleapis.com/css2?family=Anton&family=Barlow+Condensed:wght@400;600;700&family=Barlow:wght@400;500;600&display=swap" rel="stylesheet">
<script src="https://js.pusher.com/8.2.0/pusher.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<style>
:root{--jblue:#060CE9;--jblue-dk:#03047a;--jgold:#FFD700;--jgold-dk:#b89a00;--jred:#e63946;--jgreen:#2dc653;--jwhite:#f0f2ff;--panel:rgba(255,255,255,0.06);--pb:rgba(255,255,255,0.13);--r:8px}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%}
body{font-family:'Barlow',sans-serif;background:#02031a;color:var(--jwhite);min-height:100vh;overflow-x:hidden}
.screen{display:none;min-height:100vh}
.screen.active{display:flex;flex-direction:column}

/* ── SETUP ── */
#setup-screen{background:radial-gradient(ellipse at 50% -10%,#1525d4 0%,#02031a 60%);align-items:center;padding:2rem 1rem 3rem}
.splash{text-align:center;margin-bottom:2rem}
.splash h1{font-family:'Anton',sans-serif;font-size:clamp(2.8rem,9vw,5.5rem);color:var(--jgold);letter-spacing:.06em;text-shadow:4px 4px 0 #7a6000,0 0 60px rgba(255,215,0,.3);line-height:1}
.splash p{font-family:'Barlow Condensed',sans-serif;font-size:.88rem;letter-spacing:.22em;text-transform:uppercase;color:rgba(255,255,255,.35);margin-top:.3rem}
.sg{display:grid;grid-template-columns:repeat(auto-fit,minmax(290px,1fr));gap:1.1rem;max-width:1100px;width:100%}
.sp{background:var(--panel);border:1px solid var(--pb);border-radius:12px;padding:1.4rem}
.sp h2{font-family:'Barlow Condensed',sans-serif;font-size:.8rem;letter-spacing:.18em;text-transform:uppercase;color:var(--jgold);margin-bottom:1.1rem;border-bottom:1px solid rgba(255,215,0,.2);padding-bottom:.45rem}
.fl{margin-bottom:.85rem}
.fl label{display:block;font-size:.7rem;text-transform:uppercase;letter-spacing:.1em;color:rgba(255,255,255,.4);margin-bottom:.28rem}
.fl input,.fl select{width:100%;background:rgba(255,255,255,.07);border:1px solid var(--pb);border-radius:var(--r);color:var(--jwhite);font-family:'Barlow',sans-serif;font-size:.88rem;padding:.52rem .75rem;transition:border-color .2s}
.fl input:focus,.fl select:focus{outline:none;border-color:var(--jgold)}
.fl select option{background:#0d0f40}
.fl .hint{font-size:.68rem;color:rgba(255,255,255,.28);margin-top:.22rem;line-height:1.5}
.fl a{color:var(--jgold)}
.pl-list{display:flex;flex-direction:column;gap:.45rem}
.pe{display:flex;gap:.45rem;align-items:center}
.pe input[type=color]{width:30px;height:30px;border-radius:50%;border:2px solid rgba(255,255,255,.2);cursor:pointer;padding:2px;background:none;flex-shrink:0}
.pe input[type=color]::-webkit-color-swatch-wrapper{padding:0}
.pe input[type=color]::-webkit-color-swatch{border-radius:50%;border:none}
.pe input[type=text]{flex:1;background:rgba(255,255,255,.07);border:1px solid var(--pb);border-radius:var(--r);color:var(--jwhite);font-family:'Barlow',sans-serif;font-size:.88rem;padding:.42rem .65rem;transition:border-color .2s}
.pe input[type=text]:focus{outline:none;border-color:var(--jgold)}
.cats-g{display:grid;grid-template-columns:1fr 1fr;gap:.45rem}
.ce label{font-size:.66rem;text-transform:uppercase;letter-spacing:.08em;color:rgba(255,255,255,.33);display:block;margin-bottom:.18rem}
.ce input{width:100%;background:rgba(255,255,255,.07);border:1px solid var(--pb);border-radius:var(--r);color:var(--jwhite);font-family:'Barlow Condensed',sans-serif;font-size:.86rem;padding:.38rem .55rem;transition:border-color .2s}
.ce input:focus{outline:none;border-color:var(--jgold)}
.btn-sm{background:var(--panel);border:1px solid var(--pb);border-radius:var(--r);color:rgba(255,255,255,.6);cursor:pointer;font-family:'Barlow Condensed',sans-serif;font-size:.8rem;letter-spacing:.05em;padding:.34rem .7rem;transition:all .15s;white-space:nowrap}
.btn-sm:hover{background:rgba(255,255,255,.12);color:#fff}
.btn-sm.danger:hover{background:rgba(230,57,70,.18);border-color:var(--jred);color:var(--jred)}
.setup-foot{grid-column:1/-1;display:flex;justify-content:center;gap:1rem;flex-wrap:wrap;margin-top:.4rem}
.btn-main{font-family:'Anton',sans-serif;font-size:1.1rem;letter-spacing:.08em;padding:.72rem 1.9rem;border-radius:var(--r);border:none;cursor:pointer;transition:all .15s}
.btn-main.primary{background:var(--jgold);color:#1a0000;box-shadow:0 4px 18px rgba(255,215,0,.25)}
.btn-main.primary:hover{background:#ffe84d;transform:translateY(-2px)}
.btn-main.secondary{background:var(--panel);color:var(--jwhite);border:1px solid var(--pb)}
.btn-main.secondary:hover{background:rgba(255,255,255,.12);transform:translateY(-1px)}

/* ── GAME SCREEN ── */
#game-screen{background:#02031a;flex-direction:row;min-height:100vh}
#sidebar{width:235px;min-width:190px;background:#04051c;border-right:2px solid rgba(255,215,0,.3);display:flex;flex-direction:column;overflow:hidden}
#sb-hd{background:linear-gradient(135deg,#06088a,var(--jblue));padding:.7rem 1rem;border-bottom:2px solid var(--jgold);text-align:center}
#sb-hd h2{font-family:'Anton',sans-serif;font-size:.95rem;letter-spacing:.14em;color:var(--jgold)}
#scores-list{flex:1;overflow-y:auto;padding:.65rem .6rem;display:flex;flex-direction:column;gap:.4rem}
.sc{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-left:3px solid transparent;border-radius:var(--r);padding:.55rem .75rem;transition:all .2s;position:relative;overflow:hidden}
.sc.ap{border-color:var(--jgold);background:rgba(255,215,0,.07);box-shadow:0 0 10px rgba(255,215,0,.15)}
.sc.bp{border-color:var(--jgreen);background:rgba(45,198,83,.07)}
.sc .sn{font-family:'Barlow Condensed',sans-serif;font-size:.8rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:rgba(255,255,255,.7);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-bottom:.18rem}
.sc .sv{font-family:'Anton',sans-serif;font-size:1.4rem;color:var(--jgold);letter-spacing:.02em;line-height:1}
.sc .sv.neg{color:var(--jred)}
.sc .srk{position:absolute;top:.4rem;right:.55rem;font-family:'Anton',sans-serif;font-size:.62rem;color:rgba(255,255,255,.18)}
.sc:nth-child(1) .srk{color:var(--jgold)}
.sc:nth-child(2) .srk{color:#c0c0c0}
.sc:nth-child(3) .srk{color:#cd7f32}
.sc .sstr{font-size:.58rem;font-family:'Barlow Condensed',sans-serif;letter-spacing:.08em;text-transform:uppercase;color:var(--jgreen);margin-top:.12rem}
#sb-ctrl{padding:.65rem;border-top:1px solid rgba(255,255,255,.08);display:flex;flex-direction:column;gap:.45rem}
#sb-ctrl label{font-size:.66rem;text-transform:uppercase;letter-spacing:.1em;color:rgba(255,255,255,.32);display:block;margin-bottom:.08rem}
.psel{background:rgba(255,255,255,.07);border:1px solid var(--pb);border-radius:var(--r);color:var(--jwhite);font-family:'Barlow',sans-serif;font-size:.8rem;padding:.35rem .55rem;width:100%}
.psel option{background:#0a0d40}
.sadj{display:flex;gap:.32rem}
.sadj input{flex:1;min-width:0;background:rgba(255,255,255,.07);border:1px solid var(--pb);border-radius:var(--r);color:var(--jwhite);font-family:'Barlow',sans-serif;font-size:.8rem;padding:.35rem .45rem}
.sadj input:focus{outline:none;border-color:var(--jgold)}
.sadj button{background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.14);border-radius:var(--r);color:#fff;cursor:pointer;font-size:.9rem;width:28px;transition:background .14s}
.sadj button:hover{background:rgba(255,255,255,.22)}
#main-area{flex:1;display:flex;flex-direction:column;min-width:0}
#game-header{background:linear-gradient(90deg,#03056e,var(--jblue),#03056e);border-bottom:3px solid var(--jgold);padding:.55rem 1.1rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.45rem}
#game-header h1{font-family:'Anton',sans-serif;font-size:1.5rem;color:var(--jgold);letter-spacing:.08em;text-shadow:2px 2px 0 #7a6000}
.round-tag{font-family:'Barlow Condensed',sans-serif;font-size:.7rem;letter-spacing:.15em;text-transform:uppercase;padding:.18rem .6rem;border-radius:20px;border:1px solid rgba(255,215,0,.28);color:rgba(255,215,0,.7)}
.round-tag.dj{border-color:rgba(255,140,0,.4);color:rgba(255,165,60,.85)}
.round-tag.fj{border-color:rgba(230,57,70,.4);color:rgba(230,100,100,.9)}
.hc{display:flex;gap:.45rem;align-items:center;flex-wrap:wrap}
.hbtn{font-family:'Barlow Condensed',sans-serif;font-size:.75rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;padding:.4rem .85rem;border-radius:var(--r);border:1px solid rgba(255,255,255,.18);background:rgba(255,255,255,.08);color:#fff;cursor:pointer;transition:all .14s}
.hbtn:hover{background:rgba(255,255,255,.17)}
.hbtn.gold{background:var(--jgold);color:#1a0000;border-color:var(--jgold)}
.hbtn.gold:hover{background:#ffe84d}
.hbtn.red{border-color:var(--jred);color:var(--jred)}
.hbtn.red:hover{background:rgba(230,57,70,.16)}
.hbtn.green{border-color:var(--jgreen);color:var(--jgreen)}
.hbtn.green:hover{background:rgba(45,198,83,.16)}
.hbtn.orange{border-color:#fb923c;color:#fb923c}
.hbtn.orange:hover{background:rgba(251,146,60,.16)}
#buzz-bar{background:rgba(255,215,0,.05);border-bottom:1px solid rgba(255,215,0,.15);padding:.45rem 1.1rem;display:flex;align-items:center;gap:.7rem;min-height:50px;flex-wrap:wrap}
#buzz-bar .bl{font-family:'Barlow Condensed',sans-serif;font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.32);white-space:nowrap}
#buzz-q-bar{display:flex;gap:.45rem;flex:1;flex-wrap:wrap;align-items:center}
.bqc{display:flex;align-items:center;gap:.45rem;padding:.28rem .75rem;border-radius:20px;border:1px solid rgba(255,255,255,.11);background:rgba(255,255,255,.05);animation:sli .25s cubic-bezier(.34,1.56,.64,1);font-family:'Barlow Condensed',sans-serif}
.bqc.fb{border-color:var(--jgold);background:rgba(255,215,0,.14);box-shadow:0 0 10px rgba(255,215,0,.22)}
.bqc .br{font-size:.62rem;color:rgba(255,255,255,.28);letter-spacing:.05em}
.bqc.fb .br{color:var(--jgold)}
.bqc .bn{font-size:.88rem;font-weight:700;letter-spacing:.04em;color:#fff}
.bqc .bt{font-size:.62rem;color:rgba(255,255,255,.32);margin-left:.15rem}
.bqc .ba{display:flex;gap:.22rem}
.bqbtn{width:22px;height:22px;border-radius:50%;border:1px solid rgba(255,255,255,.14);background:rgba(255,255,255,.06);color:#fff;cursor:pointer;font-size:.7rem;display:flex;align-items:center;justify-content:center;transition:all .12s}
.bqbtn:hover{transform:scale(1.15)}
.bqbtn.c{border-color:var(--jgreen);color:var(--jgreen)}
.bqbtn.c:hover{background:rgba(45,198,83,.2)}
.bqbtn.w{border-color:var(--jred);color:var(--jred)}
.bqbtn.w:hover{background:rgba(230,57,70,.2)}
@keyframes sli{from{opacity:0;transform:translateX(-10px)}to{opacity:1;transform:translateX(0)}}
.bsp{font-family:'Barlow Condensed',sans-serif;font-size:.7rem;letter-spacing:.12em;text-transform:uppercase;padding:.18rem .65rem;border-radius:20px;white-space:nowrap}
.bsp-o{background:rgba(45,198,83,.13);color:var(--jgreen);border:1px solid rgba(45,198,83,.28)}
.bsp-l{background:rgba(230,57,70,.1);color:var(--jred);border:1px solid rgba(230,57,70,.28)}
#board-wrap{flex:1;padding:.8rem .9rem;overflow-y:auto}
#board{display:grid;gap:5px;width:100%}
.cat-hd{background:var(--jblue);border:2px solid rgba(255,255,255,.13);border-radius:var(--r);font-family:'Anton',sans-serif;font-size:clamp(.55rem,1.2vw,.88rem);letter-spacing:.05em;text-align:center;color:var(--jwhite);padding:.6rem .25rem;min-height:54px;display:flex;align-items:center;justify-content:center;line-height:1.2;text-transform:uppercase}
.vtile{background:var(--jblue);border:2px solid rgba(255,255,255,.12);border-radius:var(--r);cursor:pointer;display:flex;align-items:center;justify-content:center;font-family:'Anton',sans-serif;font-size:clamp(.85rem,2vw,1.5rem);color:var(--jgold);text-shadow:1px 2px 0 rgba(0,0,0,.4);min-height:62px;transition:background .12s,transform .1s,box-shadow .1s;position:relative}
.vtile:hover:not(.used){background:#1220e0;transform:scale(1.03);box-shadow:0 0 16px rgba(255,215,0,.18);border-color:var(--jgold);z-index:2}
.vtile.used{background:#0a0d4a;cursor:default;color:transparent;border-color:rgba(255,255,255,.04)}
.vtile.dj-tile{color:#ffb347}
.vtile.dd::after{content:'★';position:absolute;top:3px;right:5px;font-size:.6rem;color:rgba(255,215,0,.32)}
.vtile.act{border-color:var(--jgold);box-shadow:0 0 22px rgba(255,215,0,.32)}

/* ── ROUND TRANSITION ── */
#round-overlay{display:none;position:fixed;inset:0;background:#02031a;z-index:300;align-items:center;justify-content:center;flex-direction:column;gap:1.4rem;padding:2rem;text-align:center}
#round-overlay.show{display:flex;animation:fdIn .4s ease}
@keyframes fdIn{from{opacity:0}to{opacity:1}}
.ro-label{font-family:'Barlow Condensed',sans-serif;font-size:.88rem;letter-spacing:.25em;text-transform:uppercase;color:rgba(255,255,255,.35)}
.ro-title{font-family:'Anton',sans-serif;font-size:clamp(2.5rem,9vw,6.5rem);color:var(--jgold);letter-spacing:.06em;text-shadow:5px 5px 0 #7a6000,0 0 80px rgba(255,215,0,.35);animation:roIn .6s cubic-bezier(.34,1.56,.64,1)}
@keyframes roIn{from{opacity:0;transform:scale(.6)}to{opacity:1;transform:scale(1)}}
.ro-sub{font-family:'Barlow Condensed',sans-serif;font-size:.95rem;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.38);max-width:500px}
.sb-preview{display:flex;gap:.75rem;flex-wrap:wrap;justify-content:center;margin-top:.3rem}
.sbp-card{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.11);border-radius:10px;padding:.75rem 1.1rem;text-align:center;min-width:105px}
.sbp-card .spn{font-family:'Barlow Condensed',sans-serif;font-size:.78rem;letter-spacing:.08em;text-transform:uppercase;color:rgba(255,255,255,.48);margin-bottom:.28rem}
.sbp-card .sps{font-family:'Anton',sans-serif;font-size:1.45rem;color:var(--jgold)}
.sbp-card .sps.neg{color:var(--jred)}

/* ── FINAL JEOPARDY ── */
#fj-screen{background:radial-gradient(ellipse at 50% 0%,#1a0840 0%,#02031a 65%);align-items:center;padding:2rem 1rem 2rem}
.fj-header{text-align:center;margin-bottom:1.8rem;width:100%}
.fj-header h1{font-family:'Anton',sans-serif;font-size:clamp(2rem,6vw,4rem);color:var(--jred);letter-spacing:.06em;text-shadow:3px 3px 0 #7a0010,0 0 60px rgba(230,57,70,.3)}
.fj-header .fj-sub{font-family:'Barlow Condensed',sans-serif;font-size:.82rem;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,.32);margin-top:.28rem}
.fj-body{width:100%;max-width:920px;display:grid;grid-template-columns:1fr 1fr;gap:1.1rem}
@media(max-width:660px){.fj-body{grid-template-columns:1fr}}
.fj-panel{background:var(--panel);border:1px solid var(--pb);border-radius:12px;padding:1.3rem}
.fj-panel h2{font-family:'Barlow Condensed',sans-serif;font-size:.78rem;letter-spacing:.16em;text-transform:uppercase;color:var(--jgold);margin-bottom:.95rem;border-bottom:1px solid rgba(255,215,0,.18);padding-bottom:.42rem}
.fj-input{width:100%;background:rgba(255,255,255,.07);border:1px solid var(--pb);border-radius:var(--r);color:var(--jwhite);font-family:'Barlow Condensed',sans-serif;font-size:.95rem;letter-spacing:.05em;padding:.55rem .8rem;margin-bottom:.65rem;transition:border-color .2s}
.fj-input:focus{outline:none;border-color:var(--jgold)}
textarea.fj-input{resize:vertical;min-height:75px;font-family:'Barlow',sans-serif;font-size:.87rem;line-height:1.5}
.fj-clue-box{background:rgba(6,12,233,.2);border:2px solid rgba(6,12,233,.5);border-radius:10px;padding:1.1rem;text-align:center;font-family:'Barlow Condensed',sans-serif;font-size:clamp(.95rem,2.3vw,1.5rem);font-weight:600;color:#fff;line-height:1.4;min-height:75px;display:flex;align-items:center;justify-content:center;margin-bottom:.75rem}
.fj-ans-reveal{display:none;font-family:'Barlow Condensed',sans-serif;font-size:1.15rem;font-weight:700;color:var(--jgreen);letter-spacing:.06em;text-transform:uppercase;text-align:center;margin-bottom:.75rem;animation:fdIn .3s}
.wager-rows,.result-rows{display:flex;flex-direction:column;gap:.45rem}
.wager-row,.rr{display:flex;align-items:center;gap:.55rem;padding:.48rem .65rem;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:var(--r)}
.wr-name,.rr-name{font-family:'Barlow Condensed',sans-serif;font-size:.85rem;font-weight:600;letter-spacing:.05em;text-transform:uppercase;flex:1;color:rgba(255,255,255,.72)}
.wr-score{font-family:'Anton',sans-serif;font-size:.9rem;color:var(--jgold);margin-right:.25rem;white-space:nowrap}
.wr-score.neg{color:var(--jred)}
.wr-input{width:85px;background:rgba(255,255,255,.08);border:1px solid var(--pb);border-radius:var(--r);color:#fff;font-family:'Anton',sans-serif;font-size:.9rem;padding:.32rem .45rem;text-align:center;transition:border-color .2s}
.wr-input:focus{outline:none;border-color:var(--jgold)}
.rr-wager{font-family:'Anton',sans-serif;font-size:.8rem;color:rgba(255,255,255,.38);white-space:nowrap}
.rr-btns{display:flex;gap:.32rem}
.rr-btn{font-family:'Barlow Condensed',sans-serif;font-size:.72rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;padding:.26rem .65rem;border-radius:var(--r);border:1px solid transparent;cursor:pointer;transition:all .12s;white-space:nowrap}
.rr-btn.c{background:var(--jgreen);color:#001a06}
.rr-btn.c:hover{background:#3ddf63}
.rr-btn.w{background:var(--jred);color:#fff}
.rr-btn.w:hover{background:#f04550}
.rr-btn.done{background:rgba(255,255,255,.08);color:rgba(255,255,255,.38);cursor:default;border-color:rgba(255,255,255,.08)}
.fj-foot{grid-column:1/-1;display:flex;justify-content:center;gap:.75rem;flex-wrap:wrap;margin-top:.25rem}

/* ── CLUE MODAL ── */
#clue-overlay{display:none;position:fixed;inset:0;background:rgba(2,3,20,.9);z-index:100;align-items:center;justify-content:center;backdrop-filter:blur(5px)}
#clue-overlay.open{display:flex}
#clue-modal{background:var(--jblue);border:3px solid var(--jgold);border-radius:14px;box-shadow:0 0 60px rgba(255,215,0,.22);max-width:660px;width:92vw;padding:1.7rem 2rem;text-align:center;animation:popIn .25s cubic-bezier(.34,1.56,.64,1);position:relative}
@keyframes popIn{from{opacity:0;transform:scale(.85)}to{opacity:1;transform:scale(1)}}
.cmeta{font-family:'Barlow Condensed',sans-serif;font-size:.72rem;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,255,255,.38);margin-bottom:.8rem}
.cval{font-family:'Anton',sans-serif;font-size:1.7rem;color:var(--jgold);margin-bottom:.9rem}
.cval.djv{color:#ffb347}
#clue-text{font-family:'Barlow Condensed',sans-serif;font-size:clamp(1rem,2.6vw,1.75rem);font-weight:600;color:#fff;line-height:1.4;min-height:52px;margin-bottom:1.1rem}
#reveal-answer{display:none;font-family:'Barlow Condensed',sans-serif;font-size:1.25rem;font-weight:700;color:var(--jgreen);letter-spacing:.06em;text-transform:uppercase;margin-bottom:.9rem;animation:fdIn .3s}
@keyframes fdIn{from{opacity:0}to{opacity:1}}
.dd-banner{font-family:'Anton',sans-serif;font-size:2.3rem;color:var(--jgold);text-shadow:3px 3px 0 #7a6000;letter-spacing:.1em;display:none;margin-bottom:.6rem}
.dd-banner.show{display:block;animation:ddP .4s cubic-bezier(.34,1.56,.64,1)}
@keyframes ddP{from{opacity:0;transform:scale(.5) rotate(-5deg)}to{opacity:1;transform:scale(1) rotate(0)}}
#dd-sec{display:none;margin-bottom:.9rem;padding:.7rem .9rem;background:rgba(255,215,0,.07);border:1px solid rgba(255,215,0,.22);border-radius:var(--r)}
#dd-sec label{font-family:'Barlow Condensed',sans-serif;font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.42);display:block;margin-bottom:.32rem}
#dd-wager{background:rgba(255,255,255,.08);border:1px solid var(--jgold);border-radius:var(--r);color:#fff;font-family:'Anton',sans-serif;font-size:1.2rem;padding:.35rem .65rem;width:120px;text-align:center}
#dd-wager:focus{outline:none}
.award-row{display:flex;gap:.38rem;flex-wrap:wrap;justify-content:center;margin-bottom:.8rem}
.abtn{font-family:'Barlow Condensed',sans-serif;font-size:.72rem;letter-spacing:.08em;text-transform:uppercase;padding:.26rem .7rem;border-radius:20px;border:1px solid rgba(255,255,255,.16);background:rgba(255,255,255,.06);color:rgba(255,255,255,.65);cursor:pointer;transition:all .13s}
.abtn:hover{background:rgba(255,215,0,.18);border-color:var(--jgold);color:var(--jgold)}
.abtn.sel{background:rgba(255,215,0,.26);border-color:var(--jgold);color:var(--jgold)}
.cactions{display:flex;gap:.6rem;justify-content:center;flex-wrap:wrap}
.cbtn{font-family:'Barlow Condensed',sans-serif;font-size:.88rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;padding:.52rem 1.2rem;border-radius:var(--r);border:1px solid transparent;cursor:pointer;transition:all .12s}
.cbtn.correct{background:var(--jgreen);color:#001a06}
.cbtn.correct:hover{background:#3ddf63;transform:scale(1.03)}
.cbtn.wrong{background:var(--jred);color:#fff}
.cbtn.wrong:hover{background:#f04550;transform:scale(1.03)}
.cbtn.neutral{background:rgba(255,255,255,.1);color:#fff;border-color:rgba(255,255,255,.16)}
.cbtn.neutral:hover{background:rgba(255,255,255,.18)}
#ans-input{width:100%;max-width:390px;background:rgba(255,255,255,.1);border:2px solid rgba(255,255,255,.2);border-radius:var(--r);color:#fff;font-family:'Barlow Condensed',sans-serif;font-size:1.15rem;letter-spacing:.04em;padding:.55rem .85rem;text-align:center;transition:border-color .2s;margin-bottom:.9rem}
#ans-input:focus{outline:none;border-color:var(--jgold)}

/* ── EDIT MODAL ── */
#edit-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.88);z-index:200;overflow-y:auto;padding:2rem;justify-content:center}
#edit-overlay.open{display:flex}
#edit-modal{background:#080b30;border:1px solid var(--pb);border-radius:12px;max-width:870px;width:100%;padding:1.4rem;animation:popIn .2s ease;height:fit-content}
#edit-modal h2{font-family:'Anton',sans-serif;font-size:1.2rem;color:var(--jgold);letter-spacing:.06em;margin-bottom:.9rem}
.round-tabs{display:flex;gap:.5rem;margin-bottom:.9rem}
.rtab{font-family:'Barlow Condensed',sans-serif;font-size:.75rem;letter-spacing:.1em;text-transform:uppercase;padding:.32rem .85rem;border-radius:var(--r);border:1px solid var(--pb);background:rgba(255,255,255,.05);color:rgba(255,255,255,.48);cursor:pointer;transition:all .14s}
.rtab.active{background:rgba(255,215,0,.14);border-color:var(--jgold);color:var(--jgold)}
.ecs{margin-bottom:1.3rem}
.ecs h3{font-family:'Barlow Condensed',sans-serif;font-size:.8rem;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.4);margin-bottom:.42rem;border-bottom:1px solid rgba(255,255,255,.07);padding-bottom:.3rem}
.ecr{display:grid;grid-template-columns:55px 1fr 1fr auto;gap:.4rem;align-items:center;margin-bottom:.35rem}
.ecr .ev{font-family:'Anton',sans-serif;font-size:.85rem;color:var(--jgold);text-align:center}
.ecr.djr .ev{color:#ffb347}
.ecr input[type=text]{background:rgba(255,255,255,.07);border:1px solid var(--pb);border-radius:var(--r);color:#fff;font-family:'Barlow',sans-serif;font-size:.8rem;padding:.36rem .52rem}
.ecr input[type=text]:focus{outline:none;border-color:var(--jgold)}
.ecr input[type=text]::placeholder{color:rgba(255,255,255,.2)}
.ecr .ddc{accent-color:var(--jgold);width:14px;height:14px;cursor:pointer}
.edit-foot{display:flex;justify-content:flex-end;gap:.6rem;margin-top:.8rem}

/* ── SHARE MODAL ── */
#share-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:150;align-items:center;justify-content:center}
#share-overlay.open{display:flex}
#share-modal{background:#080b30;border:1px solid rgba(255,215,0,.28);border-radius:14px;padding:1.7rem;max-width:340px;width:92vw;text-align:center;animation:popIn .25s ease}
#share-modal h2{font-family:'Anton',sans-serif;font-size:1.1rem;color:var(--jgold);letter-spacing:.1em;margin-bottom:.25rem}
#share-modal p{font-family:'Barlow Condensed',sans-serif;font-size:.75rem;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.32);margin-bottom:1.1rem}
#qr-wrap{background:#fff;border-radius:var(--r);padding:9px;display:inline-block;margin-bottom:.9rem}
.surl{background:rgba(255,255,255,.06);border:1px solid var(--pb);border-radius:var(--r);color:rgba(255,255,255,.55);font-family:'Barlow Condensed',sans-serif;font-size:.74rem;padding:.4rem .65rem;width:100%;cursor:text;text-align:left;word-break:break-all;margin-bottom:.75rem;letter-spacing:.02em;user-select:all}

/* ── RESULTS ── */
#results-screen{background:radial-gradient(ellipse at 50% 20%,#1228cc 0%,#02031a 60%);align-items:center;justify-content:center;text-align:center;padding:2rem}
.trophy{font-size:4.5rem;margin-bottom:.7rem;animation:bounce 1s ease infinite alternate}
@keyframes bounce{from{transform:translateY(0)}to{transform:translateY(-10px)}}
#results-screen h1{font-family:'Anton',sans-serif;font-size:2.6rem;color:var(--jgold);letter-spacing:.06em;text-shadow:3px 3px 0 #7a6000;margin-bottom:.35rem}
#winner-name{font-family:'Barlow Condensed',sans-serif;font-size:1.5rem;letter-spacing:.1em;color:rgba(255,255,255,.78);margin-bottom:1.6rem;text-transform:uppercase}
.fs-grid{display:flex;gap:.75rem;flex-wrap:wrap;justify-content:center;margin-bottom:1.6rem;max-width:600px}
.fsc{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:.9rem 1.3rem;min-width:115px}
.fsc.first{border-color:var(--jgold);background:rgba(255,215,0,.09)}
.fsc .fn{font-family:'Barlow Condensed',sans-serif;font-size:.82rem;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.5);margin-bottom:.35rem}
.fsc .fs{font-family:'Anton',sans-serif;font-size:1.7rem;color:var(--jgold)}
.fsc .fs.neg{color:var(--jred)}

/* misc */
.toast{position:fixed;bottom:1.5rem;left:50%;transform:translateX(-50%) translateY(80px);background:#060CE9;border:1px solid var(--jgold);border-radius:6px;color:#fff;font-family:'Barlow Condensed',sans-serif;font-size:.92rem;letter-spacing:.06em;padding:.52rem 1.25rem;z-index:999;transition:transform .3s cubic-bezier(.34,1.56,.64,1);pointer-events:none;white-space:nowrap}
.toast.show{transform:translateX(-50%) translateY(0)}
.conn-ov{display:none;position:fixed;inset:0;background:rgba(2,3,26,.88);z-index:500;align-items:center;justify-content:center;flex-direction:column;gap:.9rem;font-family:'Barlow Condensed',sans-serif;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.42);font-size:.85rem;backdrop-filter:blur(4px)}
.conn-ov.show{display:flex}
.spinner{width:34px;height:34px;border:3px solid rgba(255,215,0,.16);border-top-color:var(--jgold);border-radius:50%;animation:spin .7s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.cf{animation:cfl .4s ease}
.wf{animation:wfl .4s ease}
@keyframes cfl{0%,100%{background:var(--jblue)}50%{background:rgba(45,198,83,.3)}}
@keyframes wfl{0%,100%{background:var(--jblue)}50%{background:rgba(230,57,70,.3)}}
::-webkit-scrollbar{width:5px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:rgba(255,255,255,.11);border-radius:3px}
@media(max-width:700px){#sidebar{display:none}}
</style>
</head>
<body>

<!-- SETUP -->
<div id="setup-screen" class="screen active">
  <div class="splash"><h1>JEOPARDY!</h1><p>Complete Host System — 3 Rounds</p></div>
  <div class="sg">
    <div class="sp">
      <h2>Pusher Connection</h2>
      <div class="fl"><label>Pusher Key</label><input type="text" id="pk" placeholder="abc123…"><div class="hint">Free at <a href="https://pusher.com" target="_blank">pusher.com</a> → Create App → App Keys</div></div>
      <div class="fl"><label>Cluster</label><select id="pc"><option value="mt1">mt1 — US East (recommended)</option><option value="us2">us2 — US West</option><option value="eu">eu — Europe</option><option value="ap1">ap1 — Asia Pacific</option><option value="sa1">sa1 — South America</option></select></div>
      <div class="fl"><label>Room Code</label><input type="text" id="rc" placeholder="e.g. TRIVIA1" maxlength="12" style="text-transform:uppercase;letter-spacing:.15em"></div>
    </div>
    <div class="sp">
      <h2>Game Settings</h2>
      <div class="fl"><label>Categories per Round</label><select id="nc" onchange="renderCatsGrid()"><option value="4">4</option><option value="5" selected>5</option><option value="6">6</option></select></div>
      <div class="fl"><label>Clues per Category</label><select id="nr"><option value="3">3</option><option value="4">4</option><option value="5" selected>5</option></select></div>
      <div class="fl"><label>Round 1 Base Value</label><select id="bv"><option value="100">$100/$200…</option><option value="200" selected>$200/$400…</option><option value="500">$500/$1000…</option></select></div>
      <div class="fl"><label>Daily Doubles (per round)</label><select id="ndd"><option value="0">0</option><option value="1" selected>1 — Classic</option><option value="2">2 — Double Jeopardy style</option></select></div>
      <div class="fl"><label>Wrong Answer Penalty</label><select id="wp"><option value="none">No Penalty</option><option value="half">Half Value</option><option value="full" selected>Full Value</option></select></div>
    </div>
    <div class="sp">
      <h2>Players</h2>
      <div class="pl-list" id="players-list"></div>
      <button class="btn-sm" style="margin-top:.6rem" onclick="addPlayer()">+ Add Player</button>
    </div>
    <div class="sp" style="grid-column:1/-1">
      <h2>Round 1 Categories &nbsp;<span style="color:rgba(255,255,255,.22);font-weight:400;font-size:.75em">(Double Jeopardy categories editable in-game via ✎ Edit)</span></h2>
      <div class="cats-g" id="cats-grid"></div>
    </div>
    <div class="setup-foot">
      <button class="btn-main secondary" onclick="loadDemo()">Load Demo</button>
      <button class="btn-main primary" onclick="startGame()">Launch Game →</button>
    </div>
  </div>
</div>

<!-- GAME -->
<div id="game-screen" class="screen">
  <div id="sidebar">
    <div id="sb-hd"><h2>SCOREBOARD</h2></div>
    <div id="scores-list"></div>
    <div id="sb-ctrl">
      <div><label>Active Player</label><select class="psel" id="active-sel" onchange="setActive(this.value)"></select></div>
      <div><label>Manual Adjust</label><div class="sadj"><input type="number" id="adj-amt" placeholder="±amt" step="100"><button onclick="manAdj(1)">+</button><button onclick="manAdj(-1)">−</button></div></div>
    </div>
  </div>
  <div id="main-area">
    <div id="game-header">
      <div style="display:flex;align-items:center;gap:.7rem">
        <h1>JEOPARDY!</h1>
        <span id="round-tag" class="round-tag">Round 1</span>
      </div>
      <div class="hc">
        <span id="room-pill" style="font-family:'Barlow Condensed',sans-serif;font-size:.72rem;letter-spacing:.15em;text-transform:uppercase;color:rgba(255,215,0,.62);border:1px solid rgba(255,215,0,.2);border-radius:20px;padding:.2rem .65rem">ROOM: —</span>
        <button class="hbtn green" onclick="setLock(false)">🔓 Unlock</button>
        <button class="hbtn red" onclick="setLock(true)">🔒 Lock</button>
        <button class="hbtn gold" onclick="resetRound()">↺ Reset</button>
        <button class="hbtn" onclick="openEdit()">✎ Edit</button>
        <button class="hbtn" onclick="openShare()">⬡ Share</button>
        <button class="hbtn orange" id="next-round-btn" onclick="triggerNextRound()" style="display:none">Next Round →</button>
        <button class="hbtn orange" id="fj-btn" onclick="triggerFJ()" style="display:none">Final Jeopardy →</button>
        <button class="hbtn" onclick="goSetup()">← Setup</button>
      </div>
    </div>
    <div id="buzz-bar">
      <span class="bl">BUZZERS</span>
      <span id="lock-pill" class="bsp bsp-l">🔒 Locked</span>
      <div id="buzz-q-bar"></div>
    </div>
    <div id="board-wrap"><div id="board"></div></div>
  </div>
</div>

<!-- FINAL JEOPARDY -->
<div id="fj-screen" class="screen">
  <div class="fj-header"><h1>FINAL JEOPARDY!</h1><div class="fj-sub">Everything on the line</div></div>
  <div class="fj-body">
    <div class="fj-panel">
      <h2>Category, Clue & Answer</h2>
      <div class="fl"><label>Category</label><input type="text" id="fj-cat" class="fj-input" placeholder="e.g. American Presidents"></div>
      <div class="fl"><label>Clue (read aloud)</label><textarea id="fj-clue" class="fj-input" placeholder="Enter the Final Jeopardy clue…"></textarea></div>
      <div class="fl"><label>Correct Answer</label><input type="text" id="fj-answer" class="fj-input" placeholder="What is…"></div>
      <div class="fj-clue-box" id="fj-clue-display">Clue will appear here after you reveal it</div>
      <div class="fj-ans-reveal" id="fj-ans-reveal"></div>
      <div style="display:flex;gap:.5rem;flex-wrap:wrap">
        <button class="btn-main primary" onclick="showFjClue()" style="font-size:.85rem;padding:.48rem 1rem;flex:1">Reveal Clue</button>
        <button class="btn-main secondary" onclick="showFjAnswer()" style="font-size:.85rem;padding:.48rem 1rem;flex:1">Reveal Answer</button>
      </div>
    </div>
    <div class="fj-panel">
      <h2>Wagers</h2>
      <div class="wager-rows" id="wager-rows"></div>
      <div style="margin:.9rem 0;border-top:1px solid rgba(255,255,255,.08);padding-top:.9rem">
        <div style="font-family:'Barlow Condensed',sans-serif;font-size:.75rem;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.32);margin-bottom:.45rem">Mark Results</div>
        <div class="result-rows" id="result-rows"></div>
      </div>
    </div>
    <div class="fj-foot">
      <button class="btn-main secondary" onclick="showScreen('game-screen')" style="font-size:.85rem;padding:.52rem 1.1rem">← Back to Board</button>
      <button class="btn-main primary" onclick="endGame()" style="font-size:.85rem;padding:.52rem 1.3rem">🏆 Final Scores →</button>
    </div>
  </div>
</div>

<!-- RESULTS -->
<div id="results-screen" class="screen">
  <div class="trophy">🏆</div>
  <h1>FINAL SCORES</h1>
  <div id="winner-name"></div>
  <div class="fs-grid" id="final-scores-list"></div>
  <div style="display:flex;gap:.9rem;flex-wrap:wrap;justify-content:center">
    <button class="btn-main primary" onclick="playAgain()">Play Again</button>
    <button class="btn-main secondary" onclick="goSetup()">New Game</button>
  </div>
</div>

<!-- ROUND TRANSITION -->
<div id="round-overlay">
  <div class="ro-label" id="ro-label">Up Next</div>
  <div class="ro-title" id="ro-title">DOUBLE JEOPARDY!</div>
  <div class="ro-sub" id="ro-sub">Values doubled. New categories. Same scores.</div>
  <div class="sb-preview" id="ro-scores"></div>
  <button class="btn-main primary" onclick="dismissOverlay()" style="margin-top:.4rem">Let's Play →</button>
</div>

<!-- CLUE MODAL -->
<div id="clue-overlay">
  <div id="clue-modal">
    <div class="dd-banner" id="dd-banner">DAILY DOUBLE!</div>
    <div class="cmeta" id="cmeta"></div>
    <div class="cval" id="cval"></div>
    <div id="clue-text"></div>
    <div id="dd-sec"><label>Wager Amount</label><input type="number" id="dd-wager" placeholder="0" min="0" step="100"></div>
    <input type="text" id="ans-input" placeholder="Type answer (optional)…" autocomplete="off">
    <div id="reveal-answer"></div>
    <div class="award-row" id="award-row"></div>
    <div class="cactions">
      <button class="cbtn neutral" onclick="revealAns()">Reveal Answer</button>
      <button class="cbtn correct" onclick="markResult(true)">✓ Correct</button>
      <button class="cbtn wrong" onclick="markResult(false)">✕ Wrong</button>
      <button class="cbtn neutral" onclick="closeClue()">Skip</button>
    </div>
  </div>
</div>

<!-- EDIT MODAL -->
<div id="edit-overlay">
  <div id="edit-modal">
    <h2>✎ Edit Clues & Categories</h2>
    <div class="round-tabs" id="edit-tabs"></div>
    <div id="edit-content"></div>
    <div class="edit-foot">
      <button class="btn-main secondary" onclick="closeEdit()" style="font-size:.85rem;padding:.46rem 1rem">Cancel</button>
      <button class="btn-main primary" onclick="saveEdit()" style="font-size:.85rem;padding:.46rem 1rem">Save</button>
    </div>
  </div>
</div>

<!-- SHARE MODAL -->
<div id="share-overlay">
  <div id="share-modal">
    <h2>SHARE WITH PLAYERS</h2>
    <p>Scan QR or open link on phone</p>
    <div id="qr-wrap"></div>
    <div class="surl" id="share-url"></div>
    <button class="btn-main primary" onclick="copyUrl()" style="font-size:.88rem;padding:.5rem 1.1rem;margin-bottom:.42rem">Copy Link</button><br>
    <button class="btn-sm" onclick="closeShare()" style="margin-top:.25rem">Close</button>
  </div>
</div>

<div class="conn-ov" id="conn"><div class="spinner"></div><span>Connecting…</span></div>
<div class="toast" id="toast"></div>

<script>
const COLORS=['#FFD700','#38bdf8','#f87171','#4ade80','#c084fc','#fb923c','#e879f9','#a78bfa'];
const MEDALS=['🥇','🥈','🥉'];

let G={
  pusherKey:'',pusherCluster:'mt1',roomCode:'',
  players:[],scores:[],streaks:[],
  rows:5,baseVal:200,numDDs:1,wrongPenalty:'full',
  cats:[[],[]],boards:[[], []],
  round:0,
  activePlayer:0,currentClue:null,
  buzzLocked:true,buzzQueue:[],connectedPlayers:{},
  fjWagers:[],fjDone:[],
};
let pusher=null,channel=null,editRound=0;

// ── SETUP ──
(function(){
  const pl=document.getElementById('players-list');
  [['Player 1','#FFD700'],['Player 2','#38bdf8']].forEach(([n,c])=>pl.appendChild(mkPE(n,c)));
  renderCatsGrid();
})();

function mkPE(name,color){
  const d=document.createElement('div');d.className='pe';
  d.innerHTML=`<input type="color" value="${color}"><input type="text" placeholder="Name" value="${name}"><button class="btn-sm danger" onclick="removePlayer(this)">✕</button>`;
  return d;
}
function addPlayer(){
  const list=document.getElementById('players-list');
  list.appendChild(mkPE('Player '+(list.children.length+1),COLORS[list.children.length%COLORS.length]));
}
function removePlayer(btn){
  if(document.querySelectorAll('.pe').length<=1){showToast('Need at least 1 player');return;}
  btn.closest('.pe').remove();
}
function renderCatsGrid(){
  const n=+document.getElementById('nc').value;
  const grid=document.getElementById('cats-grid');
  const ex=Array.from(grid.querySelectorAll('input')).map(i=>i.value);
  const defs=['History','Science','Pop Culture','Sports','Geography','Art','Music','Food'];
  grid.innerHTML='';
  for(let i=0;i<n;i++){const d=document.createElement('div');d.className='ce';d.innerHTML=`<label>Category ${i+1}</label><input type="text" value="${ex[i]||defs[i]||''}" placeholder="Category ${i+1}">`;grid.appendChild(d);}
}
function loadDemo(){
  document.getElementById('nc').value='5';renderCatsGrid();
  document.getElementById('nr').value='5';document.getElementById('bv').value='200';
  document.getElementById('ndd').value='1';document.getElementById('wp').value='full';
  const ci=document.querySelectorAll('#cats-grid input');
  ['U.S. History','Science','Pop Culture','Geography','Wordplay'].forEach((c,i)=>{if(ci[i])ci[i].value=c;});
  const pl=document.getElementById('players-list');pl.innerHTML='';
  [['Alex','#FFD700'],['Morgan','#38bdf8'],['Jordan','#f87171']].forEach(([n,c])=>pl.appendChild(mkPE(n,c)));
  showToast('Demo loaded!');
}

// ── START GAME ──
function startGame(){
  const key=document.getElementById('pk').value.trim();
  const cluster=document.getElementById('pc').value;
  const room=(document.getElementById('rc').value.trim().toUpperCase())||randCode();
  if(!key){showToast('Enter your Pusher key');return;}
  const numCats=+document.getElementById('nc').value;
  const numRows=+document.getElementById('nr').value;
  const baseVal=+document.getElementById('bv').value;
  const numDDs=+document.getElementById('ndd').value;
  const penalty=document.getElementById('wp').value;
  const players=Array.from(document.querySelectorAll('.pe')).map((e,i)=>({
    name:e.querySelector('input[type=text]').value.trim()||`Player ${i+1}`,
    color:e.querySelector('input[type=color]').value,
  }));
  if(!players.length){showToast('Add at least 1 player');return;}
  const r1cats=Array.from(document.querySelectorAll('#cats-grid input')).map((inp,i)=>inp.value.trim()||`Category ${i+1}`);
  const r2cats=r1cats.map(c=>`DJ: ${c}`);
  const boards=[[],[]];
  for(let rnd=0;rnd<2;rnd++){
    const mult=rnd===0?1:2;
    for(let c=0;c<numCats;c++){
      const col=[];
      for(let r=0;r<numRows;r++)col.push({clue:'',answer:'',value:baseVal*mult*(r+1),dailyDouble:false,used:false});
      boards[rnd].push(col);
    }
    const placed=new Set();let att=0;
    while(placed.size<numDDs&&att<200){att++;const c=Math.floor(Math.random()*numCats),r=Math.floor(Math.random()*numRows),k=`${c}-${r}`;if(!placed.has(k)){placed.add(k);boards[rnd][c][r].dailyDouble=true;}}
  }
  G={pusherKey:key,pusherCluster:cluster,roomCode:room,players,scores:players.map(()=>0),streaks:players.map(()=>0),rows:numRows,baseVal,numDDs,wrongPenalty:penalty,cats:[r1cats,r2cats],boards,round:0,activePlayer:0,currentClue:null,buzzLocked:true,buzzQueue:[],connectedPlayers:{},fjWagers:players.map(()=>0),fjDone:players.map(()=>false)};
  document.getElementById('room-pill').textContent='ROOM: '+room;
  initPusher(key,cluster);
  applyRoundUI();renderBoard();renderScoreboard();renderActiveSelect();renderBuzzBar();
  showScreen('game-screen');
}

// ── ROUND UI ──
function applyRoundUI(){
  const tag=document.getElementById('round-tag');
  const nrb=document.getElementById('next-round-btn');
  const fjb=document.getElementById('fj-btn');
  if(G.round===0){tag.textContent='Round 1';tag.className='round-tag';}
  else{tag.textContent='Double Jeopardy!';tag.className='round-tag dj';}
  const allUsed=G.boards[G.round].every(col=>col.every(c=>c.used));
  nrb.style.display=(allUsed&&G.round===0)?'inline-flex':'none';
  fjb.style.display=(allUsed&&G.round===1)?'inline-flex':'none';
}

function checkRoundOver(){
  const allUsed=G.boards[G.round].every(col=>col.every(c=>c.used));
  if(!allUsed)return;
  if(G.round===0)setTimeout(()=>showTransition('DOUBLE JEOPARDY!','Round 2 — Values doubled. New categories. Same scores.','dj'),500);
  else setTimeout(()=>showTransition('FINAL JEOPARDY!','The last question — everything on the line.','fj'),500);
}

function showTransition(title,sub,next){
  const ov=document.getElementById('round-overlay');
  document.getElementById('ro-label').textContent=next==='dj'?'Up Next':'Coming Up';
  document.getElementById('ro-title').textContent=title;
  document.getElementById('ro-sub').textContent=sub;
  const sorted=G.players.map((p,i)=>({...p,score:G.scores[i]})).sort((a,b)=>b.score-a.score);
  document.getElementById('ro-scores').innerHTML=sorted.map(p=>{const neg=p.score<0;return `<div class="sbp-card"><div class="spn">${escHtml(p.name)}</div><div class="sps${neg?' neg':''}" style="color:${p.color}">${neg?'-':''}$${Math.abs(p.score).toLocaleString()}</div></div>`;}).join('');
  ov._next=next;ov.classList.add('show');
}

function dismissOverlay(){
  const ov=document.getElementById('round-overlay');
  const next=ov._next;ov.classList.remove('show');
  if(next==='dj'){G.round=1;G.buzzQueue=[];setLock(true);applyRoundUI();renderBoard();renderScoreboard();renderBuzzBar();showScreen('game-screen');}
  else if(next==='fj'){launchFJ();}
}
function triggerNextRound(){showTransition('DOUBLE JEOPARDY!','Round 2 — Values doubled. Same scores.','dj');}
function triggerFJ(){showTransition('FINAL JEOPARDY!','The last question — everything on the line.','fj');}

// ── PUSHER ──
function initPusher(key,cluster){
  showConn(true);Pusher.logToConsole=false;
  pusher=new Pusher(key,{cluster});
  pusher.connection.bind('connected',()=>{showConn(false);subscribe();});
  pusher.connection.bind('error',()=>{showConn(false);showToast('Pusher error — check your key');});
}
function subscribe(){
  channel=pusher.subscribe('jeopardy-'+G.roomCode.toLowerCase());
  channel.bind('client-buzz',onBuzz);
  channel.bind('client-player-join',d=>{if(!G.connectedPlayers[d.id])G.connectedPlayers[d.id]={name:d.name,online:true};showToast(d.name+' joined!');});
}
function broadcast(ev,data){if(!channel)return;try{channel.trigger('client-'+ev,data);}catch(e){}}

// ── BUZZERS ──
function setLock(locked){G.buzzLocked=locked;if(locked){G.buzzQueue=[];renderBuzzBar();}broadcast('lock',{locked});renderBuzzBar();}
function resetRound(){G.buzzQueue=[];broadcast('reset',{});broadcast('lock',{locked:false});G.buzzLocked=false;renderBuzzBar();showToast('Buzzers unlocked');}
function onBuzz(data){
  if(G.buzzLocked||G.buzzQueue.find(b=>b.id===data.id))return;
  if(!G.connectedPlayers[data.id])G.connectedPlayers[data.id]={name:data.name,online:true};
  G.buzzQueue.push({id:data.id,name:data.name,ts:data.ts||Date.now()});
  G.buzzQueue.sort((a,b)=>a.ts-b.ts);
  if(G.buzzQueue.length===1){const mi=G.players.findIndex(p=>p.name===data.name);if(mi>=0){G.activePlayer=mi;document.getElementById('active-sel').value=mi;}playBuzz();}
  renderBuzzBar();renderScoreboard();
}
function awardBuzz(idx,correct){
  const bz=G.buzzQueue[idx];if(!bz)return;
  const value=G.currentClue?getClueVal():G.baseVal*(G.round===1?2:1);
  const pi=G.players.findIndex(p=>p.name===bz.name);
  if(pi>=0){
    if(correct){G.scores[pi]+=value;G.streaks[pi]++;G.streaks.forEach((_,i)=>{if(i!==pi)G.streaks[i]=0;});}
    else{if(G.wrongPenalty==='full')G.scores[pi]-=value;else if(G.wrongPenalty==='half')G.scores[pi]-=Math.floor(value/2);G.streaks[pi]=0;}
    broadcast('score-update',{id:bz.id,score:G.scores[pi],correct});
  }
  G.buzzQueue.splice(idx,1);renderBuzzBar();renderScoreboard();
  showToast((correct?'✓ +':'✗ -')+'$'+value.toLocaleString()+' → '+bz.name);
}
function renderBuzzBar(){
  const pill=document.getElementById('lock-pill');
  pill.textContent=G.buzzLocked?'🔒 Locked':'🔓 Open';
  pill.className='bsp '+(G.buzzLocked?'bsp-l':'bsp-o');
  const bar=document.getElementById('buzz-q-bar');
  if(!G.buzzQueue.length){bar.innerHTML='';return;}
  bar.innerHTML=G.buzzQueue.map((b,i)=>`<div class="bqc${i===0?' fb':''}"><span class="br">${i===0?'🥇':(i+1)}</span><span class="bn">${escHtml(b.name)}</span>${i>0?`<span class="bt">+${b.ts-G.buzzQueue[0].ts}ms</span>`:''}<div class="ba"><button class="bqbtn c" onclick="awardBuzz(${i},true)">✓</button><button class="bqbtn w" onclick="awardBuzz(${i},false)">✗</button></div></div>`).join('');
}

// ── BOARD ──
function renderBoard(){
  const bd=document.getElementById('board');
  const rnd=G.round,cats=G.cats[rnd],cols=cats.length;
  bd.style.gridTemplateColumns=`repeat(${cols},1fr)`;bd.innerHTML='';
  cats.forEach(cat=>{const h=document.createElement('div');h.className='cat-hd';h.textContent=cat;bd.appendChild(h);});
  for(let r=0;r<G.rows;r++){
    for(let c=0;c<cols;c++){
      const cell=G.boards[rnd][c][r];
      const t=document.createElement('div');
      t.className='vtile'+(cell.used?' used':'')+(cell.dailyDouble?' dd':'')+(rnd===1?' dj-tile':'');
      if(G.currentClue&&G.currentClue.c===c&&G.currentClue.r===r)t.classList.add('act');
      t.dataset.c=c;t.dataset.r=r;
      if(!cell.used){t.textContent='$'+cell.value.toLocaleString();t.addEventListener('click',()=>openClue(c,r));}
      bd.appendChild(t);
    }
  }
  applyRoundUI();
}

// ── CLUE ──
function openClue(c,r){
  const cell=G.boards[G.round][c][r];if(cell.used)return;
  G.currentClue={c,r};
  const isDD=cell.dailyDouble;
  document.getElementById('dd-banner').classList.toggle('show',isDD);
  document.getElementById('cmeta').textContent=G.cats[G.round][c]+' · '+(isDD?'Daily Double':'$'+cell.value.toLocaleString());
  const cv=document.getElementById('cval');cv.textContent=isDD?'':'$'+cell.value.toLocaleString();cv.className='cval'+(G.round===1?' djv':'');
  document.getElementById('clue-text').textContent=cell.clue||`[No clue set]\nCategory: ${G.cats[G.round][c]} · $${cell.value.toLocaleString()}`;
  document.getElementById('reveal-answer').style.display='none';document.getElementById('reveal-answer').textContent='';
  document.getElementById('ans-input').value='';
  document.getElementById('dd-sec').style.display=isDD?'block':'none';
  if(isDD)document.getElementById('dd-wager').value=cell.value;
  document.getElementById('award-row').innerHTML=G.players.map((p,i)=>`<button class="abtn${i===G.activePlayer?' sel':''}" onclick="selAward(${i})">${escHtml(p.name)}</button>`).join('');
  setLock(false);renderBoard();
  document.getElementById('clue-overlay').classList.add('open');
  setTimeout(()=>document.getElementById('ans-input').focus(),100);
}
function selAward(idx){G.activePlayer=idx;document.getElementById('active-sel').value=idx;document.querySelectorAll('.abtn').forEach((b,i)=>b.classList.toggle('sel',i===idx));}
function getClueVal(){const{c,r}=G.currentClue;const cell=G.boards[G.round][c][r];return cell.dailyDouble?(+document.getElementById('dd-wager').value||cell.value):cell.value;}
function revealAns(){const{c,r}=G.currentClue;const ra=document.getElementById('reveal-answer');ra.textContent='Answer: '+(G.boards[G.round][c][r].answer||'(Not set)');ra.style.display='block';}
function markResult(correct){
  const{c,r}=G.currentClue,value=getClueVal();
  const modal=document.getElementById('clue-modal');
  if(correct){G.scores[G.activePlayer]+=value;G.streaks[G.activePlayer]++;G.streaks.forEach((_,i)=>{if(i!==G.activePlayer)G.streaks[i]=0;});modal.classList.add('cf');setTimeout(()=>modal.classList.remove('cf'),400);showToast('✓ +$'+value.toLocaleString()+' → '+G.players[G.activePlayer].name);}
  else{if(G.wrongPenalty==='full')G.scores[G.activePlayer]-=value;else if(G.wrongPenalty==='half')G.scores[G.activePlayer]-=Math.floor(value/2);G.streaks[G.activePlayer]=0;modal.classList.add('wf');setTimeout(()=>modal.classList.remove('wf'),400);if(G.wrongPenalty!=='none')showToast('✗ -$'+value.toLocaleString()+' → '+G.players[G.activePlayer].name);}
  const mb=G.buzzQueue.find(b=>b.name===G.players[G.activePlayer].name);
  if(mb)broadcast('score-update',{id:mb.id,score:G.scores[G.activePlayer],correct});
  G.boards[G.round][c][r].used=true;G.buzzQueue=[];G.currentClue=null;
  setLock(true);closeClue();renderBoard();renderScoreboard();renderBuzzBar();
  checkRoundOver();
}
function closeClue(){document.getElementById('clue-overlay').classList.remove('open');G.currentClue=null;renderBoard();}

// ── SCOREBOARD ──
function renderScoreboard(){
  const sorted=G.players.map((p,i)=>({...p,score:G.scores[i],streak:G.streaks[i],idx:i})).sort((a,b)=>b.score-a.score);
  const buzzed=new Set(G.buzzQueue.map(b=>b.name));
  document.getElementById('scores-list').innerHTML=sorted.map((p,rank)=>{const neg=p.score<0,isAp=p.idx===G.activePlayer,isBp=buzzed.has(p.name);return `<div class="sc${isAp?' ap':''}${isBp?' bp':''}" style="border-left-color:${p.color}"><div class="srk">${MEDALS[rank]||''}</div><div class="sn" style="color:${p.color}">${escHtml(p.name)}</div><div class="sv${neg?' neg':''}">${neg?'-':''}$${Math.abs(p.score).toLocaleString()}</div>${p.streak>1?`<div class="sstr">🔥 ${p.streak}-streak</div>`:''}</div>`;}).join('');
}
function renderActiveSelect(){const sel=document.getElementById('active-sel');sel.innerHTML=G.players.map((p,i)=>`<option value="${i}">${escHtml(p.name)}</option>`).join('');sel.value=G.activePlayer;}
function setActive(v){G.activePlayer=+v;renderScoreboard();}
function manAdj(sign){const amt=+document.getElementById('adj-amt').value;if(!amt){showToast('Enter an amount');return;}const pi=+document.getElementById('active-sel').value;G.scores[pi]+=sign*Math.abs(amt);document.getElementById('adj-amt').value='';renderScoreboard();showToast((sign>0?'+':'-')+'$'+Math.abs(amt).toLocaleString()+' for '+G.players[pi].name);}

// ── EDIT ──
function openEdit(){editRound=G.round;buildEditTabs();buildEditContent(editRound);document.getElementById('edit-overlay').classList.add('open');}
function buildEditTabs(){document.getElementById('edit-tabs').innerHTML=`<button class="rtab${editRound===0?' active':''}" onclick="switchER(0)">Round 1</button><button class="rtab${editRound===1?' active':''}" onclick="switchER(1)">Double Jeopardy</button>`;}
function switchER(r){editRound=r;buildEditTabs();buildEditContent(r);}
function buildEditContent(rnd){
  const content=document.getElementById('edit-content');content.innerHTML='';
  G.cats[rnd].forEach((cat,ci)=>{
    const sec=document.createElement('div');sec.className='ecs';const isDJ=rnd===1;
    let rows=`<div class="ecr" style="font-size:.65rem;color:rgba(255,255,255,.24);letter-spacing:.08em;text-transform:uppercase"><span>Val</span><span>Question/Clue</span><span>Answer</span><span>DD</span></div>`;
    for(let r=0;r<G.rows;r++){const cell=G.boards[rnd][ci][r];rows+=`<div class="ecr${isDJ?' djr':''}"><span class="ev">$${cell.value}</span><input type="text" placeholder="Clue…" value="${escAttr(cell.clue)}" data-rnd="${rnd}" data-c="${ci}" data-r="${r}" data-f="clue"><input type="text" placeholder="Answer…" value="${escAttr(cell.answer)}" data-rnd="${rnd}" data-c="${ci}" data-r="${r}" data-f="answer"><input type="checkbox" class="ddc" ${cell.dailyDouble?'checked':''} data-rnd="${rnd}" data-c="${ci}" data-r="${r}" data-f="dd"></div>`;}
    sec.innerHTML=`<h3><input type="text" value="${escAttr(cat)}" data-rnd="${rnd}" data-cat="${ci}" style="background:transparent;border:none;border-bottom:1px solid rgba(255,255,255,.15);color:rgba(255,255,255,.6);font-family:'Barlow Condensed',sans-serif;font-size:.8rem;letter-spacing:.12em;text-transform:uppercase;width:240px;padding:0 0 2px 0" placeholder="Category"></h3>${rows}`;
    content.appendChild(sec);
  });
}
function saveEdit(){
  document.querySelectorAll('#edit-content [data-cat]').forEach(inp=>{const rnd=+inp.dataset.rnd,ci=+inp.dataset.cat;G.cats[rnd][ci]=inp.value.trim()||G.cats[rnd][ci];});
  document.querySelectorAll('#edit-content [data-c]').forEach(inp=>{const rnd=+inp.dataset.rnd,c=+inp.dataset.c,r=+inp.dataset.r,f=inp.dataset.f;if(f==='clue')G.boards[rnd][c][r].clue=inp.value;else if(f==='answer')G.boards[rnd][c][r].answer=inp.value;else if(f==='dd')G.boards[rnd][c][r].dailyDouble=inp.checked;});
  closeEdit();renderBoard();showToast('Saved!');
}
function closeEdit(){document.getElementById('edit-overlay').classList.remove('open');}

// ── SHARE ──
function openShare(){const url=buildPlayerUrl();document.getElementById('share-url').textContent=url;const qw=document.getElementById('qr-wrap');qw.innerHTML='';new QRCode(qw,{text:url,width:148,height:148,colorDark:'#000',colorLight:'#fff',correctLevel:QRCode.CorrectLevel.M});document.getElementById('share-overlay').classList.add('open');}
function buildPlayerUrl(){const base=window.location.href.split('?')[0].replace('jeopardy-host','jeopardy-player');const u=new URL(base);u.searchParams.set('key',G.pusherKey);u.searchParams.set('cluster',G.pusherCluster);u.searchParams.set('room',G.roomCode);return u.toString();}
function copyUrl(){navigator.clipboard.writeText(buildPlayerUrl()).then(()=>showToast('Link copied!'));}
function closeShare(){document.getElementById('share-overlay').classList.remove('open');}

// ── FINAL JEOPARDY ──
function launchFJ(){
  G.fjWagers=G.players.map(()=>0);G.fjDone=G.players.map(()=>false);
  document.getElementById('wager-rows').innerHTML=G.players.map((p,i)=>{const neg=G.scores[i]<0,max=Math.max(G.scores[i],0);return `<div class="wager-row"><span class="wr-name" style="color:${p.color}">${escHtml(p.name)}</span><span class="wr-score${neg?' neg':''}">${neg?'-':''}$${Math.abs(G.scores[i]).toLocaleString()}</span><input class="wr-input" type="number" id="w-${i}" placeholder="0" min="0" max="${max}" value="0" oninput="setWager(${i},this.value)"></div>`;}).join('');
  document.getElementById('result-rows').innerHTML=G.players.map((p,i)=>`<div class="rr" id="rr-${i}"><span class="rr-name" style="color:${p.color}">${escHtml(p.name)}</span><span class="rr-wager" id="rwg-${i}">Wager: $0</span><div class="rr-btns"><button class="rr-btn c" onclick="markFJ(${i},true)">✓ Correct</button><button class="rr-btn w" onclick="markFJ(${i},false)">✕ Wrong</button></div></div>`).join('');
  document.getElementById('fj-clue-display').textContent='Clue will appear here after you reveal it';
  document.getElementById('fj-ans-reveal').style.display='none';
  document.getElementById('fj-cat').value='';document.getElementById('fj-clue').value='';document.getElementById('fj-answer').value='';
  broadcast('fj-start',{});showScreen('fj-screen');
}
function setWager(i,val){const max=Math.max(G.scores[i],0);const w=Math.min(Math.max(+val||0,0),max);G.fjWagers[i]=w;document.getElementById('rwg-'+i).textContent='Wager: $'+w.toLocaleString();}
function showFjClue(){const cat=document.getElementById('fj-cat').value.trim()||'Final Jeopardy';const clue=document.getElementById('fj-clue').value.trim()||'[No clue entered]';document.getElementById('fj-clue-display').textContent=cat+': '+clue;broadcast('fj-clue',{cat,clue});}
function showFjAnswer(){const ans=document.getElementById('fj-answer').value.trim()||'(No answer set)';const ra=document.getElementById('fj-ans-reveal');ra.textContent='Answer: '+ans;ra.style.display='block';}
function markFJ(i,correct){
  const wager=G.fjWagers[i];
  if(correct)G.scores[i]+=wager;else G.scores[i]-=wager;
  G.fjDone[i]=true;
  document.getElementById('rr-'+i).querySelector('.rr-btns').innerHTML=`<button class="rr-btn done">${correct?'✓ Correct':'✗ Wrong'} (${correct?'+':'-'}$${wager.toLocaleString()})</button>`;
  broadcast('score-update',{id:'fj'+i,score:G.scores[i],correct,name:G.players[i].name});
  showToast((correct?'✓ +':'✗ -')+'$'+wager.toLocaleString()+' → '+G.players[i].name);
}

// ── RESULTS ──
function endGame(){
  const sorted=G.players.map((p,i)=>({...p,score:G.scores[i]})).sort((a,b)=>b.score-a.score);
  document.getElementById('winner-name').textContent='🎉 '+sorted[0].name+' wins with $'+sorted[0].score.toLocaleString()+'!';
  document.getElementById('final-scores-list').innerHTML=sorted.map((p,i)=>{const neg=p.score<0;return `<div class="fsc${i===0?' first':''}"><div class="fn">${escHtml(p.name)}</div><div class="fs${neg?' neg':''}" style="color:${p.color}">${neg?'-':''}$${Math.abs(p.score).toLocaleString()}</div></div>`;}).join('');
  showScreen('results-screen');
}
function playAgain(){
  G.scores=G.players.map(()=>0);G.streaks=G.players.map(()=>0);G.activePlayer=0;G.buzzQueue=[];G.currentClue=null;G.round=0;
  G.boards.forEach(board=>board.forEach(col=>col.forEach(c=>c.used=false)));
  applyRoundUI();renderBoard();renderScoreboard();renderBuzzBar();setLock(true);showScreen('game-screen');
}
function goSetup(){if(pusher){pusher.disconnect();pusher=null;channel=null;}showScreen('setup-screen');}

// ── SOUND ──
function playBuzz(){try{const ctx=new(window.AudioContext||window.webkitAudioContext)();const o=ctx.createOscillator(),g=ctx.createGain();o.connect(g);g.connect(ctx.destination);o.type='square';o.frequency.setValueAtTime(880,ctx.currentTime);o.frequency.exponentialRampToValueAtTime(440,ctx.currentTime+.15);g.gain.setValueAtTime(.2,ctx.currentTime);g.gain.exponentialRampToValueAtTime(.001,ctx.currentTime+.3);o.start();o.stop(ctx.currentTime+.3);}catch(e){}}

// ── HELPERS ──
function showScreen(id){document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));document.getElementById(id).classList.add('active');}
function showConn(v){document.getElementById('conn').classList.toggle('show',v);}
let _tt;function showToast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');clearTimeout(_tt);_tt=setTimeout(()=>t.classList.remove('show'),2300);}
function escHtml(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function escAttr(s){return String(s).replace(/"/g,'&quot;').replace(/'/g,'&#39;');}
function randCode(){return Math.random().toString(36).slice(2,7).toUpperCase();}

document.addEventListener('keydown',e=>{
  if(e.key==='Escape'){closeClue();closeEdit();closeShare();document.getElementById('round-overlay').classList.remove('show');}
  if(e.key==='Enter'&&document.getElementById('clue-overlay').classList.contains('open')&&document.activeElement===document.getElementById('ans-input'))revealAns();
});
document.getElementById('clue-overlay').addEventListener('click',e=>{if(e.target===document.getElementById('clue-overlay'))closeClue();});
document.getElementById('edit-overlay').addEventListener('click',e=>{if(e.target===document.getElementById('edit-overlay'))closeEdit();});
document.getElementById('share-overlay').addEventListener('click',e=>{if(e.target===document.getElementById('share-overlay'))closeShare();});
document.getElementById('rc').addEventListener('input',function(){this.value=this.value.toUpperCase();});
</script>
